generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PremiumTier {
  FREE
  PREMIUM
  FOUNDER
}

enum UsageType {
  AI_CHAT
  IMAGE
  GAME
  CODING
  LEARNING
  CREATOR
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model UserProfile {
  id               String              @id @default(cuid())
  discordId        String              @unique
  username         String
  avatarUrl        String?
  xp               Int                 @default(0)
  coins            Int                 @default(0)
  level            Int                 @default(1)
  dailyStreak      Int                 @default(0)
  aiUsageToday     Int                 @default(0)
  imageUsageToday  Int                 @default(0)
  premiumTier      PremiumTier         @default(FREE)
  preferredModel   String              @default("gemini-flash")
  lastDailyClaimAt DateTime?
  usageResetAt     DateTime            @default(now())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  achievements     UserAchievement[]
  conversations    Conversation[]
  usages           UsageEvent[]
  economyEvents    EconomyEvent[]

  @@index([xp])
  @@index([coins])
  @@index([level])
}

model Conversation {
  id        String               @id @default(cuid())
  userId    String
  channelId String
  title     String               @default("New conversation")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      UserProfile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ConversationMessage[]

  @@index([userId, updatedAt])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  model          String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Achievement {
  id          String            @id
  name        String
  description String
  rarity      AchievementRarity @default(COMMON)
  xpReward    Int               @default(0)
  coinReward  Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String       @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime     @default(now())
  user          UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model UsageEvent {
  id        String      @id @default(cuid())
  userId    String
  type      UsageType
  amount    Int         @default(1)
  metadata  Json?
  createdAt DateTime    @default(now())
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model EconomyEvent {
  id        String      @id @default(cuid())
  userId    String
  coins     Int
  reason    String
  metadata  Json?
  createdAt DateTime    @default(now())
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GuildSettings {
  id                 String   @id @default(cuid())
  guildId            String   @unique
  welcomeChannelId   String?
  logChannelId       String?
  aiNewsChannelId    String?
  enableVoiceXp      Boolean  @default(true)
  enableAiModeration Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
